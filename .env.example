# ─── Django ──────────────────────────────────────────────────────────────
DEBUG=1
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database (PostGIS) ──────────────────────────────────────────────────
DATABASE_URL=postgis://aquageo:aquageo@db:5432/aquageo

# ─── Cache / broker ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── LLM (provider-agnostic via litellm) ─────────────────────────────────
# Switching provider/model = edit these three lines, no code changes.
# litellm reads GEMINI_API_KEY itself for gemini/* models.
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.5-flash
GEMINI_API_KEY=
# Optional alternative provider (litellm reads it for anthropic/* models):
ANTHROPIC_API_KEY=

# ─── File storage ────────────────────────────────────────────────────────
STORAGE_BACKEND=local

# ─── Supabase (optional managed Postgres + Storage) ──────────────────────
SUPABASE_URL=
SUPABASE_KEY=
